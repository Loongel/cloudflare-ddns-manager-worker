# Copy to cf-ddns-deploy.env, fill real values, then run:
#   npm run deploy:test
#
# Do not commit cf-ddns-deploy.env. This template is safe to commit.

WORKER_NAME=cf-ddns
MANAGE_ENDPOINT=ddns.example.com

# Default DDNS suffix. If omitted, the deploy script uses MANAGE_ENDPOINT.
DDNS_DOMAIN=home.example.com

# Simple mode: one DDNS suffix in one Cloudflare zone.
CF_ZONE_ID=replace-with-cloudflare-zone-id

# Multi-zone mode. If set, CF_ZONE_ID is not required.
# DDNS_DOMAIN_CONFIGS=[{"domain":"home.example.com","zoneId":"zone-id-1","ttl":120,"proxied":false},{"domain":"lab.example.net","zoneId":"zone-id-2","ttl":120,"proxied":false}]

# Optional real DNS write check after deployment. Leave empty unless you want a test record.
# TEST_HOST=nas

# Optional User-Agent sent by the client and deploy health checks.
# Use a custom value in Cloudflare WAF skip rules if Bot/WAF challenges block curl.
DDNS_USER_AGENT=cf-ddns-manager-client/1.0

# Secret used by the Worker runtime to edit DNS records.
CF_API_TOKEN=replace-with-zone-dns-edit-token

# Optional. If empty, the deploy script generates and stores these in this file.
# DDNS_ADMIN_TOKEN=replace-with-random-admin-token
# DDNS_TOKEN=replace-with-random-scoped-token

# Optional. If empty and Cloudflare deployment credentials are present, the script creates KV.
# DDNS_TOKENS_KV_ID=replace-with-kv-namespace-id

# Optional non-interactive Wrangler deployment credentials.
# CLOUDFLARE_ACCOUNT_ID=replace-with-account-id
# CLOUDFLARE_API_TOKEN=replace-with-workers-deploy-token
